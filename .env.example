# .env for Local Data Platform v0.3.0
# Copy this file to .env and update values for your environment

# Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=inventory_pass

# Data Source
CSV_PATH=data/supply_chain_data.csv

# Raw Layer (v0.2.0)
RAW_SCHEMA=raw
RAW_TABLE=supply_chain_data

# Analytics Layer (v0.2.0)
ANALYTICS_SCHEMA=analytics
ANALYTICS_TABLE=supplier_summary

# Scheduling
SCHEDULE_CRON=0 9 * * *  # Daily at 9am

# Services
ADMINER_PORT=8080

# Incremental Load (v0.3.0)
WATERMARK_ENABLED=false
CONTROL_SCHEMA=control
WATERMARK_TABLE=watermarks

# Prefect Configuration
PREFECT_API_URL=http://localhost:4200/api

# =======================================
# Rollback to v0.2.0 > false
# =======================================
# WATERMARK_ENABLED=false > v0.2.0
# WATERMARK_ENABLED=true > v0.3.0
WATERMARK_ENABLED=true


# =======================================
# Incremental Load Mode
# =======================================
# Enable Incremental Load v0.3.0 > true
INCREMENTAL_MODE=true


