# .env for Local Data Platform v0.2.0

# =======================================
# DATABASE CONFIGURATION
# =======================================

# RECOMMENDED DEFAULT v0.2.0: use DB_* (priority in src/config.py)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db #update
DB_USER=inventory_user #update
DB_PASSWORD=inventory_pass #update

# LEGACY (fallback): POSTGRES_* (compatible with Docker Compose PostgreSQL)
# Uncomment if using the default docker-compose.yml file.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=inventory_db #update
POSTGRES_USER=inventory_user #update
POSTGRES_PASSWORD=inventory_pass #update

# Optional DATABASE_URL (automatically constructed from DB_* or POSTGRES_*)
# Example: DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/supply_chain_db

# =======================================
# CONFIGURAÇÕES DO PIPELINE PREFECT
# =======================================
# Used in perfect_pipeline.py, by get_config()
CSV_PATH=data/supply_chain_data.csv
RAW_SCHEMA=raw
RAW_TABLE=supply_chain_data
ANALYTICS_SCHEMA=analytics
ANALYTICS_TABLE=supply_chain_summary
SCHEDULE_CRON=0 9 * * *  # Daily at 9am

# =======================================
# LOCAL SERVICES (Docker)
# =======================================
ADMINER_PORT=8080  # Adminer to manage local PostgreSQL

#Tip: Adjust passwords and paths according to your local/Docker environment.
#Compatible with Prefect Orchestrator and PostgreSQL via Docker.